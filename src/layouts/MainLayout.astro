---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Expert Doors | Montaż drzwi i bram garażowych',
  description = 'Expert Doors — montaż drzwi i bram garażowych w Szczecinie i okolicach.',
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="home-fab" href="/expert-doors">← Strona główna</a>
    <slot />
  </body>
</html>
