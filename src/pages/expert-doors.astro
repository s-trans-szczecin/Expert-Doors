---
import MainLayout from '../layouts/MainLayout.astro';
import OrbitGarageLogo from '../components/OrbitGarageLogo.astro';

// TWÓJ NOWY LINK WDROŻENIA:
const googleScriptUrl = 'https://script.google.com/macros/s/AKfycbzQKTpqmwOWdMxMh0QOFhpWLL4k7GE_CCaQ-JtdiLqxF6HBQXerW7s1EnOu9lZXnh5T/exec';
---

<MainLayout
  title="Expert Doors Szczecin | Montaż drzwi i bram garażowych"
  description="Expert Doors Szczecin: montaż drzwi i bram garażowych w Szczecinie oraz województwie zachodniopomorskim. Zobacz ofertę usług i cennik."
>
  <header>
    <div class="container nav">
      <div class="brand">Expert <span>Doors</span></div>
      <a href="/pobierz-aplikacje" class="btn secondary">Pobierz aplikację</a>
    </div>
  </header>

  <main class="container">
    <section class="hero" id="start">
      <div>
        <h1>Kompleksowy montaż drzwi i bram garażowych</h1>
        <p class="lead">
          Działamy głównie w Szczecinie oraz na terenie województwa zachodniopomorskiego. Realizujemy pomiar, doradztwo, dostawę, montaż i
          serwis drzwi oraz bram garażowych dla klientów indywidualnych i firm.
        </p>
        <div class="cta-row">
          <a class="btn primary" href="#formularz">Wyślij zlecenie online</a>
          <a class="btn secondary" href="/oferta-cenowa">Oferta cenowa</a>
        </div>
      </div>
      <OrbitGarageLogo />
    </section>

    <section id="oferta">
      <h2 class="section-title">Nasze podstrony usług</h2>
      <div class="grid">
        <article class="card">
          <h3>Drzwi wejściowe</h3>
          <p>Montaż drzwi stalowych, aluminiowych i antywłamaniowych.</p>
          <a class="service-door-link" href="/drzwi-wejsciowe">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Drzwi segmentowe</h3>
          <p>Nowoczesne bramy segmentowe z automatyką i bezpieczeństwem.</p>
          <a class="service-door-link" href="/drzwi-segmentowe">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Drzwi wewnętrzne</h3>
          <p>Ościeżnice, skrzydła, regulacja i estetyczne wykończenia.</p>
          <a class="service-door-link" href="/drzwi-wewnetrzne">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Automatyka bram</h3>
          <p>Napędy, piloty, czujniki bezpieczeństwa i konfiguracja sterowań.</p>
          <a class="service-door-link" href="/automatyka-bram">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Serwis i regulacje</h3>
          <p>Przeglądy okresowe, awarie i precyzyjna regulacja mechaniki.</p>
          <a class="service-door-link" href="/serwis-i-regulacje">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Montaż i pomiar</h3>
          <p>Dokładny pomiar na miejscu i profesjonalny montaż zgodny z normami.</p>
          <a class="service-door-link" href="/montaz-i-pomiar">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
      </div>
    </section>

    <section id="formularz">
      <div class="panel">
        <h2 class="section-title">Formularz zlecenia</h2>
        <form method="POST" action={googleScriptUrl} id="order-form">
          <label>Imię i Nazwisko <input name="Pelne_Nazwisko" type="text" placeholder="Jan Kowalski" required /></label>
          <label>Telefon <input name="Telefon" type="tel" required /></label>
          <label>E-mail <input name="adres_mail" type="email" required /></label>
          <label>Lokalizacja realizacji <input name="Adres" type="text" value="Szczecin i okolice" required /></label>
          <label>
            Zakres usługi
            <select name="Typ_montazu" required>
              <option value="">Wybierz usługę</option>
              <option>Montaż drzwi wejściowych</option>
              <option>Montaż drzwi segmentowych</option>
              <option>Montaż drzwi wewnętrznych</option>
              <option>Automatyka bram</option>
              <option>Serwis i regulacje</option>
              <option>Montaż i pomiar</option>
            </select>
          </label>
          <label>Opis zlecenia <textarea name="Opis" placeholder="Napisz czego potrzebujesz" required></textarea></label>

          <input type="hidden" name="ID" />
          <input type="hidden" name="Numer_zlecenia" />
          <input type="hidden" name="Data_zgloszenia" />
          <input type="hidden" name="Zleceniodawca" />
          <input type="hidden" name="Imie" />
          <input type="hidden" name="Nazwisko" />
          <input type="hidden" name="Status" value="Nowe" />
          <input type="hidden" name="Termin" value="Do ustalenia" />
          <input type="hidden" name="Pomiar" value="Nie" />
          <input type="hidden" name="Kosztorys" value="Oczekuje" />
          <input type="hidden" name="Zdjecie_przed" />
          <input type="hidden" name="Zdjecie_po" />
          <input type="hidden" name="Podpis_klienta" />
          <input type="hidden" name="Uwagi" />

          <button type="submit" class="btn primary">Wyślij zlecenie</button>
          <p id="order-form-status" class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      Expert Doors · Szczecin i okolice · <a href="tel:+48533801953" style="color:white; text-decoration:none;">+48 533 801 953</a>
    </div>
  </footer>
</MainLayout>

<script is:inline>
  const orderForm = document.querySelector('#order-form');
  const orderStatus = document.querySelector('#order-form-status');

  orderForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const submitButton = orderForm.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.textContent = 'Wysyłanie...';

    if (orderStatus) {
      orderStatus.textContent = 'Trwa wysyłanie...';
      orderStatus.style.color = 'white';
    }

    const formData = new FormData(orderForm);
    
    // Logika rozdzielania Imienia i Nazwiska
    const pelne = formData.get('Pelne_Nazwisko') || '';
    const parts = pelne.trim().split(' ');
    const imie = parts[0] || '';
    const nazwisko = parts.slice(1).join(' ') || '';

    // Generowanie danych do tabeli
    const teraz = new Date();
    const dataStr = teraz.toLocaleDateString('pl-PL') + ' ' + teraz.toLocaleTimeString('pl-PL');
    const idUnikalne = 'WEB-' + Date.now();
    const nrZlecenia = 'OG-' + Math.floor(Math.random() * 9000 + 1000);

    // Ustawianie wartości dla ukrytych pól (klucze z Twojego arkusza)
    formData.set('ID', idUnikalne);
    formData.set('Numer_zlecenia', nrZlecenia);
    formData.set('Data_zgloszenia', dataStr);
    formData.set('Zleceniodawca', pelne);
    formData.set('Imie', imie);
    formData.set('Nazwisko', nazwisko);

    // Konwersja na format URLSearchParams (najbezpieczniejszy dla Google Apps Script)
    const payload = new URLSearchParams();
    for (const [key, value] of formData.entries()) {
      payload.append(key, value);
    }

    try {
      await fetch(orderForm.action, {
        method: 'POST',
        mode: 'no-cors', // Ważne dla uniknięcia błędów CORS w Google Script
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: payload.toString(),
      });

      if (orderStatus) {
        orderStatus.textContent = 'Dziękujemy! Zlecenie zostało zapisane.';
        orderStatus.style.color = '#28a745';
      }
      orderForm.reset();
      // Przywrócenie domyślnego adresu
      const addr = orderForm.querySelector('input[name="Adres"]');
      if (addr) addr.value = 'Szczecin i okolice';
      
    } catch (error) {
      if (orderStatus) {
        orderStatus.textContent = 'Wystąpił błąd. Spróbuj ponownie lub zadzwoń.';
        orderStatus.style.color = '#dc3545';
      }
      console.error('Błąd:', error);
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = 'Wyślij zlecenie';
    }
  });
</script>