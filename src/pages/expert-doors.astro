---
import MainLayout from '../layouts/MainLayout.astro';
import OrbitGarageLogo from '../components/OrbitGarageLogo.astro';

const googleScriptUrl =
  'https://script.google.com/macros/s/AKfycbw6MhZjEccZ3NfuNFBONuZcRl0MiJLVPVe4I7QfxmhPilPPYY99BjqWfgq6_gZ0yIO0/exec';
---

<MainLayout
  title="Expert Doors Szczecin | Montaż drzwi i bram garażowych"
  description="Expert Doors Szczecin: montaż drzwi i bram garażowych w Szczecinie oraz województwie zachodniopomorskim. Zobacz ofertę usług i cennik."
>
  <header>
    <div class="container nav">
      <div class="brand">Expert <span>Doors</span></div>
      <a href="/pobierz-aplikacje" class="btn secondary">Pobierz aplikację</a>
    </div>
  </header>

  <main class="container">
    <section class="hero" id="start">
      <div>
        <h1>Kompleksowy montaż drzwi i bram garażowych</h1>
        <p class="lead">
          Działamy głównie w Szczecinie oraz na terenie województwa zachodniopomorskiego. Realizujemy pomiar, doradztwo, dostawę, montaż i
          serwis drzwi oraz bram garażowych dla klientów indywidualnych i firm.
        </p>
        <div class="cta-row">
          <a class="btn primary" href="#formularz">Wyślij zlecenie online</a>
          <a class="btn secondary" href="/oferta-cenowa">Oferta cenowa</a>
        </div>
      </div>
      <OrbitGarageLogo />
    </section>

    <section id="oferta">
      <h2 class="section-title">Nasze podstrony usług</h2>
      <div class="grid">
        <article class="card">
          <h3>Drzwi wejściowe</h3>
          <p>Montaż drzwi stalowych, aluminiowych i antywłamaniowych.</p>
          <a class="service-door-link" href="/drzwi-wejsciowe">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Drzwi segmentowe</h3>
          <p>Nowoczesne bramy segmentowe z automatyką i bezpieczeństwem.</p>
          <a class="service-door-link" href="/drzwi-segmentowe">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Drzwi wewnętrzne</h3>
          <p>Ościeżnice, skrzydła, regulacja i estetyczne wykończenia.</p>
          <a class="service-door-link" href="/drzwi-wewnetrzne">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Automatyka bram</h3>
          <p>Napędy, piloty, czujniki bezpieczeństwa i konfiguracja sterowań.</p>
          <a class="service-door-link" href="/automatyka-bram">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Serwis i regulacje</h3>
          <p>Przeglądy okresowe, awarie i precyzyjna regulacja mechaniki.</p>
          <a class="service-door-link" href="/serwis-i-regulacje">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
        <article class="card">
          <h3>Montaż i pomiar</h3>
          <p>Dokładny pomiar na miejscu i profesjonalny montaż zgodny z normami.</p>
          <a class="service-door-link" href="/montaz-i-pomiar">
            <span class="door-visual" aria-hidden="true">
              <span class="door-panel"></span>
              <span class="door-handle"></span>
              <span class="door-sign">Zobacz usługę</span>
            </span>
          </a>
        </article>
      </div>
    </section>

    <section id="realizacje">
      <h2 class="section-title">Przykładowe realizacje i wykonania</h2>
      <div class="gallery">
        <figure class="realization-card">
          <img src="/images/expert-doors/realizacje/realizacja-01.jpg" alt="Drzwi wejściowe – realizacja 01" loading="lazy" onerror="this.onerror=null;this.src='/images/expert-doors/gallery-1.svg';"/>
          <figcaption>Drzwi wejściowe — realizacja 01</figcaption>
        </figure>
        <figure class="realization-card">
          <img src="/images/expert-doors/realizacje/realizacja-02.jpg" alt="Brama segmentowa – realizacja 02" loading="lazy" onerror="this.onerror=null;this.src='/images/expert-doors/gallery-2.svg';"/>
          <figcaption>Brama segmentowa — realizacja 02</figcaption>
        </figure>
      </div>
    </section>

    <section id="formularz">
      <div class="panel">
        <h2 class="section-title">Formularz zlecenia</h2>
        <p>Prosimy o wypełnienie poniższych danych, aby zgłosić zlecenie.</p>
        <form method="POST" action={googleScriptUrl} id="order-form">
          <label>Imię i nazwisko <input name="Zleceniodawca" type="text" required /></label>
          <label>Telefon <input name="Telefon" type="tel" required /></label>
          <label>
            Lokalizacja realizacji
            <input name="Adres" type="text" value="Szczecin i okolice" required />
          </label>
          <label>
            Zakres usługi
            <select name="Typ_montazu" required>
              <option value="">Wybierz usługę</option>
              <option>Montaż drzwi wejściowych</option>
              <option>Montaż drzwi segmentowych</option>
              <option>Montaż drzwi wewnętrznych</option>
              <option>Automatyka bram</option>
              <option>Serwis i regulacje</option>
              <option>Montaż i pomiar</option>
            </select>
          </label>
          <label>
            Opis zlecenia
            <textarea name="Opis" placeholder="Napisz czego potrzebujesz" required></textarea>
          </label>

          <input type="hidden" name="ID" value="" />
          <input type="hidden" name="Numer zlecenia" value="" /> 
          <input type="hidden" name="Klient" value="" />
          <input type="hidden" name="Termin" value="" />
          <input type="hidden" name="Status" value="Nowe" />
          <input type="hidden" name="Zdjecie przed" value="" />
          <input type="hidden" name="Zdjecie_po" value="" />
          <input type="hidden" name="Podpis klienta" value="" />
          <input type="hidden" name="Uwagi" value="" />

          <button type="submit" class="btn primary">Wyślij zlecenie</button>
          <p id="order-form-status" class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      Expert Doors · Szczecin i okolice · Montaż drzwi i bram garażowych
      <div class="cta-row" style="margin-top:.8rem;">
        <a class="btn secondary" href="/polityka-prywatnosci">Polityka prywatności</a>
        <a class="btn secondary" href="/regulamin">Regulamin</a>
        <a class="btn primary" href="tel:+48533801953">📞 Zadzwoń: +48 533 801 953</a>
        <a class="btn secondary" href="mailto:s.trans.szczecin@gmail.com">✉️ Napisz e-mail</a>
      </div>
    </div>
  </footer>
</MainLayout>

<script>
  const orderForm = document.querySelector('#order-form');
  const orderStatus = document.querySelector('#order-form-status');

  orderForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!(orderForm instanceof HTMLFormElement)) return;

    const submitButton = orderForm.querySelector('button[type="submit"]');
    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = true;
      submitButton.textContent = 'Wysyłanie...';
    }

    if (orderStatus) {
      orderStatus.textContent = 'Trwa wysyłanie formularza...';
      orderStatus.className = 'form-status';
    }

    const formData = new FormData(orderForm);
    
    // Ustawienie daty zgłoszenia zgodnie z nagłówkiem w arkuszu [cite: 1, 19]
    // Jeśli w arkuszu masz "Data_zgłoszenia" (przez 'ó'), zmień klucz poniżej na Data_zgłoszenia
    formData.set('Data_zgłoszenia', new Date().toLocaleString('pl-PL'));
    
    // Generowanie prostego ID na potrzeby AppSheet
    formData.set('ID', 'WEB-' + Date.now());

    const payload = new URLSearchParams();
    for (const [key, value] of formData.entries()) {
      payload.append(key, String(value));
    }

    try {
      // Używamy mode: 'no-cors' dla Google Apps Script, jeśli nie masz skonfigurowanych nagłówków CORS
      await fetch(orderForm.action, {
        method: 'POST',
        mode: 'no-cors', 
        body: payload,
      });

      // Ponieważ 'no-cors' nie zwraca czytelnej odpowiedzi, zakładamy sukces jeśli nie rzuci błędu sieci
      if (orderStatus) {
        orderStatus.textContent = 'Dziękujemy! Zgłoszenie zostało wysłane.';
        orderStatus.className = 'form-status success';
      }

      orderForm.reset();
      const locationInput = orderForm.querySelector('input[name="Adres"]');
      if (locationInput instanceof HTMLInputElement) {
        locationInput.value = 'Szczecin i okolice';
      }
    } catch (error) {
      if (orderStatus) {
        orderStatus.textContent = 'Nie udało się wysłać formularza. Spróbuj ponownie lub zadzwoń.';
        orderStatus.className = 'form-status error';
      }
      console.error('Błąd:', error);
    } finally {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        submitButton.textContent = 'Wyślij zlecenie';
      }
    }
  });
</script>