---
import MainLayout from '../layouts/MainLayout.astro';
import OrbitGarageLogo from '../components/OrbitGarageLogo.astro';

// TWOJE NAJNOWSZE WDROŻENIE (WERSJA 3):
const googleScriptUrl = 'https://script.google.com/macros/s/AKfycbzQKTpqmwOWdMxMh0QOFhpWLL4k7GE_CCaQ-JtdiLqxF6HBQXerW7s1EnOu9lZXnh5T/exec';
---

<MainLayout
  title="Expert Doors Szczecin | Montaż drzwi i bram garażowych"
  description="Expert Doors Szczecin: montaż drzwi i bram garażowych w Szczecinie oraz województwie zachodniopomorskim."
>
  <header>
    <div class="container nav">
      <div class="brand">Expert <span>Doors</span></div>
      <a href="/pobierz-aplikacje" class="btn secondary">Pobierz aplikację</a>
    </div>
  </header>

  <main class="container">
    <section class="hero" id="start">
      <div>
        <h1>Kompleksowy montaż drzwi i bram garażowych</h1>
        <p class="lead">Szczecin i województwo zachodniopomorskie. Profesjonalny montaż i serwis.</p>
        <div class="cta-row">
          <a class="btn primary" href="#formularz">Wyślij zlecenie online</a>
          <a class="btn secondary" href="/oferta-cenowa">Oferta cenowa</a>
        </div>
      </div>
      <OrbitGarageLogo />
    </section>

    <section id="formularz">
      <div class="panel">
        <h2 class="section-title">Formularz zlecenia</h2>
        <form method="POST" action={googleScriptUrl} id="order-form">
          <label>Imię i Nazwisko <input name="Pelne_Nazwisko" type="text" placeholder="Jan Kowalski" required /></label>
          <label>Telefon <input name="Telefon" type="tel" required /></label>
          <label>E-mail <input name="adres_mail" type="email" required /></label>
          <label>Lokalizacja <input name="Adres" type="text" value="Szczecin i okolice" required /></label>
          <label>
            Zakres usługi
            <select name="Typ_montazu" required>
              <option value="">Wybierz usługę</option>
              <option>Montaż drzwi wejściowych</option>
              <option>Montaż drzwi segmentowych</option>
              <option>Montaż drzwi wewnętrznych</option>
              <option>Automatyka bram</option>
              <option>Serwis i regulacje</option>
              <option>Montaż i pomiar</option>
            </select>
          </label>
          <label>Opis <textarea name="Opis" placeholder="Napisz czego potrzebujesz" required></textarea></label>

          <input type="hidden" name="ID" />
          <input type="hidden" name="Numer_zlecenia" />
          <input type="hidden" name="Data_zgloszenia" />
          <input type="hidden" name="Zleceniodawca" />
          <input type="hidden" name="Imie" />
          <input type="hidden" name="Nazwisko" />
          <input type="hidden" name="Status" value="Nowe" />
          <input type="hidden" name="Termin" value="Do ustalenia" />
          <input type="hidden" name="Pomiar" value="Nie" />
          <input type="hidden" name="Kosztorys" value="Oczekuje" />
          <input type="hidden" name="Uwagi" />

          <button type="submit" class="btn primary">Wyślij zlecenie</button>
          <p id="order-form-status" class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      Expert Doors · Szczecin · <a href="tel:+48533801953" style="color:white;">+48 533 801 953</a>
    </div>
  </footer>
</MainLayout>

<script is:inline>
  const orderForm = document.querySelector('#order-form');
  const orderStatus = document.querySelector('#order-form-status');

  orderForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const submitButton = orderForm.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.textContent = 'Wysyłanie...';

    if (orderStatus) {
      orderStatus.textContent = 'Trwa wysyłanie...';
      orderStatus.style.color = 'white';
    }

    const formData = new FormData(orderForm);
    
    // Rozdzielanie imienia i nazwiska
    const pelne = formData.get('Pelne_Nazwisko') || '';
    const parts = pelne.trim().split(' ');
    const imie = parts[0] || '';
    const nazwisko = parts.slice(1).join(' ') || '';

    // Dane techniczne
    const teraz = new Date();
    const dataStr = teraz.toLocaleDateString('pl-PL') + ' ' + teraz.toLocaleTimeString('pl-PL');
    const idUnikalne = 'ID-' + Date.now();
    const nrZlecenia = 'OG-' + Math.floor(Math.random() * 9000 + 1000);

    // Przypisanie do pól arkusza
    formData.set('ID', idUnikalne);
    formData.set('Numer_zlecenia', nrZlecenia);
    formData.set('Data_zgloszenia', dataStr);
    formData.set('Zleceniodawca', pelne);
    formData.set('Imie', imie);
    formData.set('Nazwisko', nazwisko);

    const payload = new URLSearchParams();
    for (const [key, value] of formData.entries()) {
      payload.append(key, value);
    }

    try {
      await fetch(orderForm.action, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: payload.toString(),
      });

      if (orderStatus) {
        orderStatus.textContent = 'Sukces! Dane zostały przesłane do arkusza.';
        orderStatus.style.color = '#28a745';
      }
      orderForm.reset();
      const addr = orderForm.querySelector('input[name="Adres"]');
      if (addr) addr.value = 'Szczecin i okolice';
      
    } catch (error) {
      if (orderStatus) {
        orderStatus.textContent = 'Błąd połączenia. Zadzwoń: +48 533 801 953';
        orderStatus.style.color = '#dc3545';
      }
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = 'Wyślij zlecenie';
    }
  });
</script>