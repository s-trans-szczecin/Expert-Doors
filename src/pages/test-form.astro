---
// src/pages/test-form.astro
const googleUrl = 'https://script.google.com/macros/s/AKfycbxjswqj7BDl5TzpI3FWTlxUKajdggqqdDEtwyGO3uBhk5pmpIIsApXZ-U1-4dHaGu1J/exec';
---

<html>
<head><title>Test Formularza</title></head>
<body>
  <h1>Test zapisu do arkusza</h1>
  
  <form id="test-form" action={googleUrl}>
    <input name="Nazwisko" type="text" placeholder="Imię i Nazwisko" required /><br><br>
    <input name="Telefon" type="text" placeholder="Telefon" required /><br><br>
    <input name="Email" type="email" placeholder="Email" required /><br><br>
    <textarea name="Wiadomosc" placeholder="Wiadomość"></textarea><br><br>
    <button type="submit">WYŚLIJ TEST</button>
  </form>

  <script is:inline>
    const form = document.querySelector('#test-form');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new URLSearchParams(new FormData(form));

      try {
        await fetch(`${form.action}?${formData.toString()}`, {
          method: 'POST',
          mode: 'no-cors'
        });
        alert('Wysłano! Sprawdź arkusz.');
        form.reset();
      } catch (err) {
        alert('Błąd: ' + err);
      }
    });
  </script>
</body>
</html>